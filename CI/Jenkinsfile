pipeline {
    agent any

    environment {
        DOCKERHUB_CREDS = credentials('docker')
        LC_ALL = "en_US.UTF-8"
        LANG    = "en_US.UTF-8"
        LANGUAGE = "en_US.UTF-8"
        POSTGRESQL_HOST = "db"
        POSTGRESQL_PORT = "5432"
        POSTGRESQL_DB = "mydb"
        // DVC кэш будет храниться на хосте, чтобы не качать данные повторно
        DVC_CACHE_DIR = "C:\\dvc_cache"
        DVC_REMOTE_NAME = "local_storage"
        DVC_REMOTE_URL = "C:\\dvc_remote"
    }

    options {
        timestamps()
        skipDefaultCheckout(true)
    }

    stages {
        stage('Clone github repository') {
            steps {
                cleanWs()
                bat 'chcp 65001 && git clone -b main https://github.com/Nikita-123-orange/devops-laba3.git'
            }
        }

        stage('Install DVC') {
            steps {
                bat 'python -m pip install --upgrade pip'
                bat 'pip install dvc'
            }
        }

        stage('Pull data with DVC') {
            steps {
                dir('devops-laba3') {
                    // Создаём директории для кэша и удалённого хранилища, если их нет
                    bat 'if not exist %DVC_CACHE_DIR% mkdir %DVC_CACHE_DIR%'
                    bat 'if not exist %DVC_REMOTE_URL% mkdir %DVC_REMOTE_URL%'

                    // Настраиваем DVC remote (локальную папку) и кэш
                    bat '''
                        dvc remote add -d %DVC_REMOTE_NAME% %DVC_REMOTE_URL% || echo "Remote already exists"
                        dvc remote modify %DVC_REMOTE_NAME% --local url %DVC_REMOTE_URL%
                        set DVC_CACHE_DIR=%DVC_CACHE_DIR%
                        dvc pull --remote %DVC_REMOTE_NAME%
                    '''
                }
            }
        }

        stage('Verify data') {
            steps {
                dir('devops-laba3') {
                    // Показываем содержимое папок, где могут лежать данные (например, data/)
                    bat 'dir /s data 2>nul || echo "No data folder found"'
                }
            }
        }
        stage('Checkout repo dir') {
            steps {
                bat 'chcp 65001 && cd devops-laba3 && dir'
				}
			}

        stage('Login to Docker Hub') {
            steps {
                bat 'chcp 65001 && docker login -u %DOCKERHUB_CREDS_USR% -p %DOCKERHUB_CREDS_PSW%'
            }
        }

        stage('Build and run containers') {
            steps {
                script {
                    dir('devops-laba3') {
                        // Останавливаем контейнеры и удаляем тома (чтобы БД пересоздалась с новым паролем)
                        bat 'docker-compose down -v'
                        bat 'docker-compose build'
                    }
                    withCredentials([
                        string(credentialsId: 'postgres-user', variable: 'POSTGRESQL_USER'),
                        string(credentialsId: 'postgres-password', variable: 'POSTGRESQL_PASSWORD')
                    ]) {
                        withEnv([
                            "POSTGRES_USER=${POSTGRESQL_USER}",
                            "POSTGRES_PASSWORD=${POSTGRESQL_PASSWORD}",
                            "POSTGRES_HOST=${POSTGRESQL_HOST}",
                            "POSTGRES_PORT=${POSTGRESQL_PORT}",
                            "POSTGRES_DB=${POSTGRESQL_DB}"
                        ]) {
                            dir('devops-laba3') {
                                bat 'docker-compose up -d'
                            }
                        }
                    }
                }
            }
        }

        stage('Check application logs') {
            steps {
                dir('devops-laba3') {
                    bat '''
                        for /f %%i in ('docker ps -qf "name=^devops-laba3-web-1"') do set cid=%%i
                        if not "%cid%"=="" docker logs --tail 50 %cid%
                        if "%cid%"=="" echo "No container running"
                    '''
                }
            }
        }

        stage('Push Docker image') {
            steps {
                bat 'docker push nikita123orange/devops-laba3:latest'
            }
        }
    }

    post {
        always {
            node('windows') {
                bat 'docker logout'
            }
        }
    }
}